{% if item.durationGame is not null %}

    <span class="span_duration_game ">Durée: {{ item.durationGame.name }}.</span>

{% else %}

    {% if is_granted('ROLE_BENEVOLE') %}

        <i class="fa-solid fa-person text-danger"> Durée de la partie non renseigné!!!!</i>

    {% endif %}

{% endif %}

