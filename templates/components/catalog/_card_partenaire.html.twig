<div class="col-6 mx-auto col-sm-4 col-lg-3 col-xl-2 my-3">
    <div class="card col-12 p-0 h-100">
        <div class="card-header text-center bg-primary text-white">
            {{ partner.name | raw }} <br/>
        </div>
        <div class="card-body d-flex flex-column align-items-center justify-content-between">
            <p class="d-flex justify-content-center align-items-center h-100">
                <img class="img-thumbnail" src="{{ asset('build/images/partners/'~ partner.image)  }}"/>
            </p>
        </div>
        <div class="card-footer text-center">
            <a class="btn btn-outline-info" href="{{ partner.fullUrl }}" target="_blank">Voir le site</a>
        </div>
    </div>
</div>