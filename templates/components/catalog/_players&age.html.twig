{% if item.playersMax is not null %}
    
    {% if item.playersMin.name == item.playersMax.name %}

        {% if item.playersMin.name > 1 %}
            {% set dataJoueur = 'joueurs' %}
        {% else %}
            {% set dataJoueur = 'joueurs' %}
        {% endif %}

        <i class="fa-solid fa-person"></i> Uniquement {{ item.playersMin.name }} {{ dataJoueur }}

    {% else %}

        <i class="fa-solid fa-person"></i> De {{ item.playersMin.name }} à {{ item.playersMax.name }} joueurs.
        
    {% endif %}
    
{% else %}

    <i class="fa-solid fa-person text-danger"> Nbre de joueurs non renseigné !!!!</i>

{% endif %}

