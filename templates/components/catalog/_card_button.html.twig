{% if is_granted('ROLE_USER') %}
    {% if donnee.boite is defined %}
    {# si on affiche des occasions #}
        <a class="btn btn-sm btn-info " href="{{ path('app_occasion', {'reference_occasion': donnee.reference, 'boite_slug': donnee.boite.slug , 'editor_slug': donnee.boite.editor.slug }) }}">Voir les détails</a>
    {% else %}
        <a class="btn btn-sm btn-info " href="{{ path('app_catalogue_pieces_detachees_demande', {'id': boite.id, 'slug':boite.slug , 'editorSlug': boite.editor.slug  }) }}">Voir les pièces disponiblent</a>
    {% endif %}
{% else %}
    <a href="{{ path('app_login') }}" class="btn btn-sm btn-warning mt-3 mb-2 ">Merci de vous identifier</a>
{% endif %}