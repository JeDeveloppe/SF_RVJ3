<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>REFAITES VOS JEUX | {% block title %}{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="msapplication-TileColor" content="#da532c">
        <meta name="theme-color" content="#ffffff">
        {% include "site/googleAnalytics/googleAnalytics.html.twig" %}
        {% include "components/sharing/facebook/meta_facebook.html.twig" %}
        <meta name="description" content="">
        {% block meta %}
        {% endblock %}
        <link rel="icon" href="/build/images/favicon/favicon.ico">
        <link rel="apple-touch-icon" sizes="180x180" href="/build/images/favicon/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/build/images/favicon/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/build/images/favicon/favicon-16x16.png">
        <link rel="manifest" href="/build/images/favicon/site.webmanifest">

        {{ encore_entry_link_tags('site') }}
        
        {% block stylesheets %}
        {% endblock %}

        <script src="https://kit.fontawesome.com/39dfe16fa3.js" crossorigin="anonymous"></script>
        
    </head>
    <body>

        <div class="container-fullwidth">

            {% include "components/_cookies_alert.html.twig" %}

            {% include "components/sharing/facebook/fb_root.html.twig" %}
                
            {% include "components/_navbar.html.twig" %}

            {% include "components/_marquee.html.twig" %}

            {% include "components/_flash_message.html.twig" %}

            {% block body %}{% endblock %}

            {% include "components/_footer.html.twig" %}

        </div>

        {{ encore_entry_script_tags('site') }}

        {% block javascript %}{% endblock %}
    </body>
</html>
