
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="row justify-content-center" style="z-index: 2000">
                <div class="liveToast card position-absolute col-11 col-md-6 col-lg-4 p-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="card-header text-white bg-{{ label }}">
                        <strong class="me-auto">Notification</strong>
                    </div>
                    <div class="card-body">
                        {{ message }}
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endfor %}
