{% extends 'components/_base.html.twig' %}

{% block title %}Prestations{% endblock %}

{% block body %}

    <h1 class="col-12 mt-5 text-center">Nos <span class="text_violet">prestations</span></h1>

    <div class="row justify-content-around align-items-stretch my-5">

      {% for benefit in benefits %}
          <div class="col-11 my-4 col-md-6 col-lg-5">
            <div class="card p-0 h-100">
              <div class="card-header p-2">
                <h3 class="fs-9 fw-medium col-12 text-center h5">{{ benefit.title }}</h3>
              </div>
              <div class="card-body d-flex flex-column">
                <div class="col-12 d-flex flex-column justify-content-around text-center">
                    <div class="fs-5">{{ benefit.priceHt }}</div>
                    <div class="fs-9 text-secondary-light small">{{ benefit.priceInfo }}</div>
                </div>
                <div class="col-12 mt-4">
                  {{ benefit.description | raw }}
                </div>
              </div>
            </div>
          </div>
      {% endfor %}

    </div>

    <div class="row justify-content-center my-5">

      {% include "site/project/components/_link_to_contact_page.html.twig" %}

    </div>

{% endblock %}