{% extends "site/base.html.twig" %}

{% block title %}Bienvenue !{% endblock %}

{% block body %}

<div class="row my-5">
    <div class="col-12 cover-container shadow d-flex justify-content-center align-items-center">
        <p class="fs-4">Un service pour compléter ses jeux de société, en acheter d'occasion et donner ceux dont on ne veut plus (même incomplets).</p>
    </div>
</div>

<div class="row justify-content-around my-5">
        <div class="col-10 col-sm-9 col-md-4 mt-3 mt-md-0">
            <div class="card border-0 shadow-lg h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                    <img src="https://random.imagecdn.app/250/250" alt="" style="border-radius:50%;max-width:150px;">
                    <div class="card-description text-center fs-4 mt-4">
                        <a class="btn btn-outline-secondary" href="{{ path('app_catalogue_pieces_detachees') }}">Pièces détachées</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-10 col-sm-9 col-md-4 mt-3 mt-md-0">
            <div class="card border-0 shadow-lg h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                    <img src="https://random.imagecdn.app/250/250" alt="" style="border-radius:50%;max-width:150px;">
                    <div class="card-description text-center fs-4 mt-4">
                        <a class="btn btn-outline-secondary" href="{{ path('app_catalogue_occasions') }}">Jeux d'occasion</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-10 col-sm-9 col-md-4 mt-3 mt-md-0">
            <div class="card border-0 shadow-lg h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                    <img src="https://random.imagecdn.app/250/250" alt="" style="border-radius:50%;max-width:150px;">
                    <div class="card-description text-center fs-4 mt-4">
                        <a class="btn btn-outline-secondary" href="">Autre thème important...</a>
                    </div>
                </div>
            </div>
        </div>


</div>

{% endblock %}
