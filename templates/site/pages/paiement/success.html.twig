{% extends 'components/_base.html.twig' %}

{% block title %}Paiement terminé{% endblock %}

{% block body %}
    <div class="row justify-content-center py-5 bg-white">
        <div class="jumbotron col-11 col-md-6 my-5 h-100">
            <h1 class="display-4">PAIEMENT TERMINÉ</h1>
            <p class="lead">Nous vous remerçions de votre commande!</p>
