{% include "components/forms/_display_form_errors.html.twig" %}

    {{ form_start(form) }}
        <div class="col-12 col-lg-12 d-flex flex-column flex-wrap justify-content-around">
            <div class="col-12 mb-3">
                <label class="label_in_occasion_search_form">{{ form_label(form.search) }}</label>
                {{ form_widget(form.search) }}
            </div>
            <div class="col-11 mb-3">
                <label class="label_in_occasion_search_form">{{ form_label(form.age_start) }}</label>
                {{ form_widget(form.age_start) }}
            </div>
            <div class="col-12">
                <label class="label_in_occasion_search_form">{{ form_label(form.playerMin) }}</label>
                <ul class="d-flex flex-wrap justify-content-start flex-wrap mt-2 p-0">
                    {% for player in form.playerMin %}
                            <li class="list-unstyled li_players"> {{ form_widget(player,{ 'attr': {'class': 'checkbox_players'} }) }} <span class="majesticCheckbox">{{ form_label(player) }} </span></li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col-12">
                <label class="label_in_occasion_search_form">{{ form_label(form.duration) }}</label>
                <ul class="d-flex flex-wrap justify-content-start flex-wrap mt-2 p-0">
                    {% for time in form.duration %}
                            <li class="list-unstyled li_durations"> {{ form_widget(time,{ 'attr': {'class': 'checkbox_times'} }) }} <span class="majesticCheckbox">{{ form_label(time) }} </span></li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col-12">
                {% set currentPath = path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')) %}
                <div class="input-group-append text-center col-12">
                    <div class="btn-group" role="group">
                        <button type="submit" class="btn btn-dark">Chercher</button>
                        <a href="{{ currentPath }}" type="button" class="btn btn-orange">Reset</a>
                    </div>
                </div>
            </div>
        </div>
    {{ form_end(form) }}
