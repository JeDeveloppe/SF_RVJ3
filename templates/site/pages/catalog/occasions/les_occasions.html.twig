{% extends "components/_base.html.twig" %}

{% block title %}Les jeux d'occasion{% endblock %}

{% block body %}

    {% if fairDay is not null %}
        <!-- foire en cours -->
        {% include "components/catalog/_fairDay.html.twig" %}

    {% else %}
        <!-- pas de foire en cours -->
        <div class="row justify-content-around py-4">
            {{ titreDeLaPage | raw }}
        </div>
        <div class="row justify-content-around py-5 bg-white">
            <!-- left column / searchs -->
            <div class="col-11 col-md-4 col-lg-3 col-xl-3 px-0 d-flex flex-wrap justify-content-around">
                {% include "site/pages/catalog/components/_search_occasion.html.twig" %}
            </div>
            <!-- rigth column / results -->
            <div id="results" class="col-11 col-md-8 col-lg-9 d-flex flex-wrap justify-content-around justify-content-md-start align-items-stretch mt-5 mt-md-0">
                    <!-- left column / result > 0 -->
                    {% if occasions | length > 0 %}

                        {% set jeu_dispo = 'jeu d\'occasion disponible' %}

                        {% if occasions | length > 1 %}
                            {% set jeu_dispo = 'jeux d\'occasion disponibles' %}
                        {% endif %}

                            <div class="col-12 font-weight-bolder mb-3">{{ occasions_totales | length }} {{ jeu_dispo }}.</div>

                            {% for key,occasion in occasions %}  

                                <div class="col-9 col-sm-6 col-lg-4 mx-md-0 p-1">
                                    {% include "site/pages/catalog/components/_cardOccasion.html.twig" with { 'product': occasion, 'tax': tax } %}
                                </div>

                            {% endfor %}

                            <div class="col-12 my-5">
                                {{ knp_pagination_render(occasions, 'components/_pagination.html.twig') }}
                            </div>

                    {% else %}

                        <!-- left column / result == 0 -->
                        {% include "site/pages/catalog/components/_emptyResultsDisplayPartners.html.twig" with {'partners': partners } %}
                        
                    {% endif %}
            </div>
        </div>

    {% endif %}
{% endblock %}

{% block javascript %}
<script>
    window.onload = () => {

        let FormOccasion = document.getElementById('search_occasions_in_catalogue');

        document.querySelectorAll('#search_occasions_in_catalogue input').forEach(input => {
            input.addEventListener('change', () => {
                let Form = new FormData(FormOccasion);

                //on recupere les donnees
                let Params = new URLSearchParams();

                Form.forEach((value, key) => {
                    Params.append(key, value);
                    console.log(Params.toString())
                })

                //on recupere url active
                let Url = new URL(window.location.href);

                //on lance fetch()
                fetch(Url.pathname + "?" + Params.toString() + "&ajax=1", {
                    headers: {
                        "x-Request-with": "XMLHttpRequest"
                    }
                })
                .then(response => response.json())
                .then(data => {
                    let content = document.querySelector("#results");
                    content.innerHTML = data.content;

                    //on met a jour l'url
                    history.pushState([], null, Url.pathname + "?" + Params.toString())
                }).catch(e => alert(e))
            })
        });

    }
</script>
{% endblock %}