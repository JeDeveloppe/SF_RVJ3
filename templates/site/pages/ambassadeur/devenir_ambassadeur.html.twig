                <div class="card-body">
                    <span class="card_ambassadeur_number">
                        <i class="fa-solid fa-circle fa-8x position-relative"></i>
                        <i class="fa-solid fa-2 fa-5x text-orange position-absolute"></i>
                    </span>
                    <h6 class="text-dark text-center mt-3">Collectez les jeux </h6>
                    <div class="card-text">
