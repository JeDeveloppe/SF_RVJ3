{% if displayProductsInCart == true %}

    {% include "site/pages/panier/components/_table_items.html.twig" with {'donnees': allCartValues['panier_items'] } %}

    {% for key, panier in allCartValues['panier_occasions'] %}
        <!-- item_panier -->
        <div class="col-12 card rounded-4 mb-3 px-0">
            <div class="card-body d-flex flex-wrap justify-content-around align-items-center px-0">
                <div class="col-11 text-end d-md-none"><a href="{{ path('delete_cart_line_when_not_logged', {'category': 'occasions', 'cart_id': panier.occasion.id }) }}"><i class="fa-solid fa-xmark text-yellow fa-2x" alt="supprimer du panier"></i></a></div>
                <!-- item_panier_img -->
                <div class="col-11 col-sm-3 d-flex flex-column justify-content-center align-items-center">
                    <img class="img-fluid" src="{{ vich_uploader_asset(panier.occasion.boite, 'imageFile') }}"/>
                    <p class="info_photo mt-3">Photo non contractuelle</p>
                </div>

                <!-- item_panier_details -->
                <div class="col-11 col-sm-7">
                    <div class="col-11 text-end d-none d-md-block"><a href="{{ path('delete_cart_line_when_not_logged', {'category': 'occasions', 'cart_id': panier.occasion.id }) }}"><i class="fa-solid fa-xmark text-yellow fa-2x" alt="supprimer du panier"></i></a></div>
                    <div class="col-11 occasion_detail_editor">{{ panier.occasion.boite.editor }}</div>
                    <div class="col-11">{{ panier.occasion.boite.name | raw }}</div>
                    <div class="col-11 d-flex flex-wrap flex-column justify-content-around">
                        <table class="col-12 small">
                            <tr>
                                <td>Boite <i class="fa-solid fa-circle" style="color: {{ panier.occasion.boxCondition.color }};width:2px;height:2px;"></i></td>
                                <td>Matériel <i class="fa-solid fa-circle" style="color: {{ panier.occasion.equipmentCondition.color }};width:2px;height:2px;"></i></td>
                                <td>Règle du jeu <i class="fa-solid fa-circle" style="color: {{ panier.occasion.gameRule.color }};width:2px;height:2px;"></i></td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-11">
                        <div class="col-6 mt-3 text-end fw-bolder">{% include "components/occasion/_display_occasion_price.html.twig" with {'product': panier.occasion,'tax': allCartValues['tax']} %}</div>
                        <div class="col-6 __shop"><img src="{{ asset('build/images/design/cart/shop_retrait.svg') }}" alt="Logo shop_retrait"> Retrait sur Caen</div>
                    </div>

                </div>
            </div>
        </div>
    {% endfor %}
{% endif %}