{% extends "components/_base.html.twig" %}

{% block title %}Panier{% endblock %}

{% block body %}


{% include "site/pages/panier/components/_header_panier.html.twig" with {'page': 'adresses'} %}

<div class="row justify-content-center bg-white py-5 align-items-start">
    <!-- partie panier -->
    <div class="col-11 col-md-8 col-lg-6 d-flex flex-wrap">
        {% include "site/pages/panier/components/_billingAndDeliveryForm.html.twig" %}
    </div>
    <!-- partie récapitulatif -->
    <div class="col-11 col-md-8 mt-4 mt-md-0 col-lg-5">
        <h3 class="col-12 px-0">Récapitulatif</h3>
        <div class="col-12 card rounded-4 p-0">
            {% include "site/pages/panier/components/_recapitulatif.html.twig" with {'displayOccasions': true, 'displayItems': true, 'displayVoucher': false, 'displayShippingMethod': false, 'javascript': false } %}
        </div>
    </div>
</div>

{% endblock %}