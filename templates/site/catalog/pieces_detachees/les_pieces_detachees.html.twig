{% extends "site/base.html.twig" %}

{% block title %}Catalogue des pièces détachées{% endblock %}

{% block body %}

    <div class="col-12 text-center h2 my-5">Les pièces détachées</div>

    {% if boites | length > 0 %}

        <div class="row justify-content-start align-items-stretch mb-5">

            {% include "components/catalog/_card.html.twig" with { 'donnees': boites } %}

        </div>
        
        {% if boites | length > 0 %}

            <div class="row">
                <div class="col-12 d-flex justify-content-center">
                    {{ knp_pagination_render(boites, 'components/pagination.html.twig') }}
                </div>
            </div>

        {% endif %}

        <div class="row mb-5">
            <div class="col-12 text-center">{{ boites_totales | length }} boites en ligne.</div>
        </div>

    {% else %}

        <div class="row">
            <div class="col-12 text-center">
                <p class="h2">Nous n'avons pas ce jeu en stock pour le moment.</p>
                <p class="h5">Vous pouvez suivre nos arrivages sur la page <a href="https://www.refaitesvosjeux.fr" target="_blank">Facebook !</a></p>    
                <p class="h5 mt-5">Ou tenter votre chance chez l'un de nos partenaires:</p>
            </div>
        </div>
        <div class="row justify-content-start mb-5">

            {% for partenaire in partenaires %}

            {% include "site/components/catalogues/card-partenaire.html.twig" %}
                
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
