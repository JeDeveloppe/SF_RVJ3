{% extends "components/_base.html.twig" %}

{% block title %}Espace membre{% endblock %}

{% block body %}

<div class="row justify-content-center py-5 bg-white">
    <div class="col-11 col-sm-4 d-flex flex-wrap py-4">
        <h2 class="col-12 text-center text-sm-start">
            Mon compte
        </h2>
        <ul class="list-unstyled d-none d-sm-block">
            <li>Mes commandes</li>
            <li>Mes adresses</li>
            <li>Mes paramètres</li>
        </ul>
    </div>
    <div class="col-9 col-sm-6 card_member_all_themes d-flex flex-wrap flex-column flex-md-row align-items-center justify-content-center py-2">
            {% for theme in themes %}
                <div class="card_member_theme d-flex flex-column align-items-center m-2 position-relative">
                    <a href="{{ theme.link }}" class="_card_full_button"></a>
                    <img src="{{ asset('build/images/design/member/bigLogos/' ~ theme.imgName ~ '.svg') }}" class="mt-4" alt="Logo des {{ theme.imgName }}">
                    <h5 class="card-title text-purple mt-4">{{ theme.title }}</h5>
                </div>
            {% endfor %}
    </div>
</div>

{% include "components/_separateur_wave.html.twig" %}

{% endblock %}