<div class="col-12 col-md-7 mx-auto">
    {{ form_start(form) }}
        <div class="mb-3">
            {{ form_row(form.isFacturation) }}
        </div>
        <div class="mb-3">
            {{ form_row(form.organization) }}
        </div>
        <div class="mb-3">
            {{ form_row(form.lastname) }}
        </div>          
        <div class="mb-3">
            {{ form_row(form.firstname) }}
        </div>
        <div class="mb-3">
            {{ form_row(form.street) }}
        </div>
        <div class="mb-3">
            {{ form_row(form.city) }}
        </div>

        <div class="col-12 text-center">
            <button class="btn btn-success my-3">{{ button_label|default('Enregistrer') }}</button>
        </div>
    {{ form_end(form) }}
</div>