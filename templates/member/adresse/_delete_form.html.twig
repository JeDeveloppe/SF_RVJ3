<form method="post" class="ms-2" action="{{ path('adresse_delete', {'id': adresse}) }}" onsubmit="return confirm('Vous êtes sûr de vouloir supprimer cette adresse?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ adresse) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
